{
  "hosting": [
    {
      "target": "cephas",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [{"key": "Cache-Control", "value": "max-age=3600"}]
        },
        {
          "source": "**/*.css",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        },
        {
          "source": "**/*.js",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        },
        {
          "source": "/download/**",
          "headers": [
            {"key": "X-LB-Version", "value": "v0.1.3"},
            {"key": "X-LB-Build-Hash", "value": "v0.1.3+2a41b63"},
            {"key": "X-LB-Phase", "value": "alpha"}
          ]
        },
        {
          "source": "/changelog/**",
          "headers": [
            {"key": "X-LB-Version", "value": "v0.1.3"},
            {"key": "Cache-Control", "value": "max-age=1800"}
          ]
        }
      ]
    },
    {
      "target": "museum",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [{"key": "Cache-Control", "value": "max-age=3600"}]
        },
        {
          "source": "**/*.css",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        },
        {
          "source": "**/*.js",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        }
      ]
    },
    {
      "target": "mnemosyne",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/", "destination": "/download/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [{"key": "Cache-Control", "value": "max-age=3600"}]
        },
        {
          "source": "**/*.css",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        },
        {
          "source": "**/*.js",
          "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
        },
        {
          "source": "/download/**",
          "headers": [
            {"key": "X-LB-Version", "value": "v0.1.3"},
            {"key": "X-LB-Build-Hash", "value": "v0.1.3+2a41b63"},
            {"key": "X-LB-Phase", "value": "alpha"}
          ]
        },
        {
          "source": "/changelog/**",
          "headers": [
            {"key": "X-LB-Version", "value": "v0.1.3"},
            {"key": "Cache-Control", "value": "max-age=1800"}
          ]
        }
      ]
    }
  ]
}
