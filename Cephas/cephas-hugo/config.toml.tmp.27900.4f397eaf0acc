baseURL = "https://cephas.lianabanyan.com/"
languageCode = "en-us"
title = "Cephas - Liana Banyan Knowledge Center"
theme = "PaperMod"
refLinksErrorLevel = "error"
copyright = "Ã¢â€Â¬Ã¢Å’Â 2026 Liana Banyan Corporation. All rights reserved."
enableRobotsTXT = true
buildFuture = true
ignoreFiles = ["_AUGUR_.*SUPERSEDE.*\\.md$"]
[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true

[pagination]
  pagerSize = 10

[params]
  hideFooter = true
  description = "The authoritative source for understanding Liana Banyan's philosophy, economics, and mission"
  author = "Liana Banyan Corporation"
  defaultTheme = "dark"
  ShowReadingTime = true
  ShowShareButtons = true
  ShowPostNavLinks = true
  ShowBreadCrumbs = true
  ShowCodeCopyButtons = true
  ShowWordCount = true
  ShowRssButtonInSectionTermList = true
  UseHugoToc = true

  [params.homeInfoParams]
    Title = "Cephas: The Foundation"
    Content = "The math is here. The system architecture is here. The human story is here."

  [[params.socialIcons]]
    name = "email"
    url = "mailto:support@lianabanyan.org"

  [[params.socialIcons]]
    name = "github"
    url = "https://github.com/lianabanyan"

  [params.fuseOpts]
    isCaseSensitive = false
    shouldSort = true
    location = 0
    distance = 1000
    threshold = 0.4
    minMatchCharLength = 0
    keys = ["title", "permalink", "summary", "content"]

  [params.label]
    text = "Liana Banyan"
    icon = "/LianaBanyanLogo.png"
    iconHeight = 50

