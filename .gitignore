# ============================================
# K441 — librarian-mcp reproducibility carve-outs
# ============================================
# The internal librarian-mcp/ directory hosts source for the in-repo MCP
# server. Several of its critical files (package.json, tsconfig.json,
# package-lock.json, registry.yaml, SP*.md spec files, README) are caught
# by the broad *.json / *.yaml / *.md ignore rules above. Without these
# explicit negations, a fresh clone cannot `npm install` the librarian
# and the Cathedral cannot start. .ts source files under librarian-mcp/src/
# are not affected (no `*.ts` ignore rule exists in this file).
#
# DO NOT re-broaden these patterns without ALSO updating librarian-mcp/README.md
# (which documents the policy).
!librarian-mcp/package.json
!librarian-mcp/package-lock.json
!librarian-mcp/tsconfig.json
!librarian-mcp/README.md
!librarian-mcp/stitchpunks/scribes/registry.yaml
!librarian-mcp/stitchpunks/SP*.md
!librarian-mcp/stitchpunks/README.md
!librarian-mcp/stitchpunks/knight_cathedral/README.md
!librarian-mcp/stitchpunks/knight_cathedral/schema.json
!librarian-mcp/stitchpunks/knight_cathedral/registry.yaml
!librarian-mcp/stitchpunks/pawn_cathedral/README.md
!librarian-mcp/stitchpunks/pawn_cathedral/schema.json
!librarian-mcp/stitchpunks/pawn_cathedral/registry.yaml
!librarian-mcp/stitchpunks/pawn_cathedral/keys/cooperative_attestation.md
!librarian-mcp/stitchpunks/scribes/schema.json
!librarian-mcp/r10_cross_vendor/README.md
!librarian-mcp/scrambler/README.md
!librarian-mcp/touchstone/README.md
# Index payloads and runtime state stay ignored — they are regenerable
# via `npm run rebuild` and would bloat git history. Force-adding them is
# explicitly NOT desired.
librarian-mcp/index/*.json
librarian-mcp/index/*.jsonl
librarian-mcp/stitchpunks/sp*_state.json

# ============================================
# B117 follow-up — Stitchpunk Corps Python source
# ============================================
# Same class of reproducibility fix as K441 Half B. The root `*.py` ignore
# rule catches runtime-critical Python source under librarian-mcp/stitchpunks/
# (SP-1 Cartographer, SP-5 Sentinel, SP-6 Scribe, SP-16 Recombiner, SP-18
# Prose Provenance, SP-20 Pollinator, session_start.py, session_end.py, etc.).
# Without these negations a fresh clone cannot run the Stitchpunk Corps.
# __pycache__/ and *.pyc stay ignored (generated).
!librarian-mcp/stitchpunks/*.py
!librarian-mcp/stitchpunks/**/*.py
librarian-mcp/stitchpunks/**/__pycache__/
librarian-mcp/stitchpunks/**/*.pyc

# ============================================
# K442 (B117) — TouchStone engine + predicates carve-out
# ============================================
# The root `*.py` / `*.json` ignore rules also catch runtime-critical files
# under librarian-mcp/touchstone/ (verify.py, ledger.py, predicates/*.py,
# manifest.json, manifest_schema.json, the migrate_letter_predicates.py
# tooling, and the tests/ subtree). Without these negations the K442
# 3-state Letter Predicate Ladder system cannot reach a fresh clone, and
# `python touchstone/verify.py --letters-summary` (called by brief_me) and
# `python touchstone/migrate_letter_predicates.py --apply` would silently
# fail. __pycache__/ and *.pyc stay ignored (generated).
!librarian-mcp/touchstone/*.py
!librarian-mcp/touchstone/**/*.py
!librarian-mcp/touchstone/manifest.json
!librarian-mcp/touchstone/manifest_schema.json
librarian-mcp/touchstone/**/__pycache__/
librarian-mcp/touchstone/**/*.pyc
# Append-only ledger stays ignored — runtime state, not source.
librarian-mcp/touchstone/ledger.jsonl

# ============================================
# K455c (B121) — Cross-Cathedral benchmark scripts + results
# ============================================
# The root `*.py` / `*.json` ignore rules catch the R11 cross-cathedral
# benchmark orchestrator, adapter, and results JSON files. These are
# reproducibility-critical for the cooperative-corpus flywheel empirical test.
!librarian-mcp/r10_cross_vendor/*.py
!librarian-mcp/r10_cross_vendor/**/*.py
!librarian-mcp/r10_cross_vendor/results_r11_v3_cross_cathedral_K455c/*.json

# ============================================
# K471 (B121) — R11 corpus-bank realignment carve-outs
# ============================================
# The root *.json / *.mjs ignore rules catch the sealed question banks and
# the reseal verification script. These are reproducibility-critical for
# the K471 bank realignment and all subsequent R11 benchmark runs.
!librarian-mcp/r10_cross_vendor/R11_QUESTION_BANK_SEALED_K471.json
!librarian-mcp/r10_cross_vendor/R11_QUESTION_BANK_SEALED_K444_LEGACY.json
!librarian-mcp/r10_cross_vendor/scripts/reseal-question-bank.mjs
!librarian-mcp/r10_cross_vendor/results_r11_k471_realignment/*.json
!librarian-mcp/r10_cross_vendor/results_r11_k471_realignment/*.jsonl
!librarian-mcp/r10_cross_vendor/results_r11_k471_realignment/*.csv
!librarian-mcp/r10_cross_vendor/results_r11_k471_realignment/*.md
!librarian-mcp/tests/test_r11_bank_realignment.mjs

# ============================================
# K474 (B122) — Self-Indexing Scribes auto-keyword sidecars + benchmark results
# ============================================
# The root *.yaml / *.py / *.json / *.mjs ignore rules catch the corpus-derived
# auto-keyword sidecar YAMLs, the rebuild CLI, the unit tests, the Phase B/C
# benchmark orchestrator, and the result files. Without these negations, a
# fresh clone cannot regenerate or validate the Tier-2 distinctiveness keywords
# and the Cathedral Effect empirics become unreproducible.
# The auto_keywords directory name contains "_key" which triggers the *_KEY*
# secrets-filter on Windows (case-insensitive match). Negating both the
# directories and their contents is required to un-ignore these sidecars.
!librarian-mcp/stitchpunks/scribes/auto_keywords/
!librarian-mcp/stitchpunks/knight_cathedral/auto_keywords/
!librarian-mcp/stitchpunks/pawn_cathedral/auto_keywords/
!librarian-mcp/stitchpunks/scribes/auto_keywords/*.yaml
!librarian-mcp/stitchpunks/knight_cathedral/auto_keywords/*.yaml
!librarian-mcp/stitchpunks/pawn_cathedral/auto_keywords/*.yaml
# K475: BRIDLE.yaml and KnightQueue.yaml sidecars were gitignored in K474 due to
# corpus-explosion exceeding 1 MB. K475 D3 adds a MAX_KEYWORDS_PER_SIDECAR=2000 hard cap
# (autoExtract.ts), bringing both under 50 KB. They are now committed normally.
!librarian-mcp/scripts/rebuild_auto_keywords.mjs
!librarian-mcp/tests/test_auto_extract.mjs
!librarian-mcp/r10_cross_vendor/run_r11_k474.py
!librarian-mcp/r10_cross_vendor/run_r12_pawn_comet.py
!librarian-mcp/r10_cross_vendor/results_r11_k474_auto_only/*.json
!librarian-mcp/r10_cross_vendor/results_r11_k474_auto_only/*.jsonl
!librarian-mcp/r10_cross_vendor/results_r11_k474_union/*.json
!librarian-mcp/r10_cross_vendor/results_r11_k474_union/*.jsonl
!librarian-mcp/r10_cross_vendor/results_r12_pawn_comet/*.jsonl
!librarian-mcp/r10_cross_vendor/results_r12_pawn_comet/*.json

# ============================================
