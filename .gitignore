.idea/
*.swp
*.swo
.vscode/settings.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.cache/
.parcel-cache/
.eslintcache

# Firebase (keep firebase.json but ignore caches)
