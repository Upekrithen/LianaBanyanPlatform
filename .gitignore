# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
dist/
build/
.next/
out/
# Vite dev-server config timestamp artifacts (auto-regenerated on dev reload)
**/vite.config.ts.timestamp-*.mjs
**/vite.config.*.timestamp-*.mjs

# Python bytecode caches — never commit
__pycache__/
*.pyc
*.pyo
*.pyd

# R10 Eyewitness benchmark aggregate result (regenerable) — committed as .gz instead
# Decompress locally with: gunzip -k <file>.gz
**/all_graded.jsonl

# Environment files (SENSITIVE)
.env
.env.*
.env.local
.env.*.local
**/.env
**/.env.*
**/.env.local
**/.env.*.local

# Defense-in-depth: credential patterns (secondary protection)
# Primary protection is directory-level (Asteroid-ProofVault/ on line 72)
# These patterns catch secrets if they ever leak outside the vault
**/API_KEYS*
**/FounderSECRETS*
**/DOUBLESECRET*
**/LockBox/
*_SECRETS.md
*_secrets.json
*_SECRET*
*_KEY*
*_TOKEN*
**/credentials.json
**/service-account*.json
**/firebase-adminsdk*.json

