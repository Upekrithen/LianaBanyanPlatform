# lb-reproducibility-pack -- API Key Configuration
# Copy this file to .env and fill in your keys.
# The benchmark uses YOUR keys to call AI vendor APIs directly.
# No LB server keys required. No telemetry. Sovereignty guaranteed.

# Required for cold_haiku, cold_sonnet, claude_projects_*, lb_cathedral_*:
ANTHROPIC_API_KEY=

# Required for cold_gpt4o_mini, chatgpt_memory, lb_cathedral_gpt4o_mini:
OPENAI_API_KEY=

# Required for cold_gemini_flash, gemini_gems, lb_cathedral_gemini_flash:
GOOGLE_API_KEY=

# Required for perplexity_spaces:
PERPLEXITY_API_KEY=
