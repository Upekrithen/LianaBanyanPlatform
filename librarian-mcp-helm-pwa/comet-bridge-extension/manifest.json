{
  "manifest_version": 3,
  "name": "Comet Bridge — Cathedral Injection",
  "version": "0.2.1",
  "description": "Zero-paste Cathedral context injection for Perplexity/Comet queries via local Helm PWA daemon. K508: network-intercept architecture replaces K485A DOM approach.",

  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:7712/*",
    "*://*.perplexity.ai/*",
    "*://perplexity.ai/*",
    "*://*.comet.com/*",
    "*://comet.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Comet Bridge"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.perplexity.ai/*",
        "*://perplexity.ai/*",
        "*://*.comet.com/*",
        "*://comet.com/*"
      ],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.perplexity.ai/*",
        "*://perplexity.ai/*",
        "*://*.comet.com/*",
        "*://comet.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
