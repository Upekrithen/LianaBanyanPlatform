          {/* Section 2 */}
          <section className="py-8" data-xray-id="pi-section-2">
            <h2 className="text-2xl font-semibold mb-4">Not Left. Not Right. Forward.</h2>
            <div className="grid md:grid-cols-3 gap-4">
              <Card>
                <CardContent className="pt-4">
                  <h3 className="font-medium mb-2">Individualism</h3>
                  <p className="text-sm text-muted-foreground">&ldquo;I don&apos;t need you.&rdquo; Every person for themselves. Markets solve everything.</p>
                </CardContent>
              </Card>
              <Card>
                <CardContent className="pt-4">
                  <h3 className="font-medium mb-2">Collectivism</h3>
                  <p className="text-sm text-muted-foreground">&ldquo;You must serve the group.&rdquo; The group decides for everyone. Central planning solves everything.</p>
