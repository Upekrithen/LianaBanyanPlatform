  "corpus": {
    "ingestPipeline": {
      "skippingStones": "Think of a postal sorting facility. The second your letter hits the conveyor, a barcode goes on the envelope. From that moment on, the whole system knows exactly where it is and who it came from.",
      "wadingIn": "The Ingest Pipeline is the moment the cooperative makes a promise. 'We received this. We know who sent it. We will remember.' Every Crown Jewel and every provisional patent in the 228 + 21 catalog starts here."
    },
    "costPlus20": {
      "skippingStones": "Imagine a store where every price tag shows: item cost, markup, and your savings -- all three numbers, always visible. That's the whole economy.",
      "wadingIn": "Cost+20% means the platform adds exactly 20% to cover operations. No more, no less. Every member can verify the math. Hidden markup is structurally impossible."
    },
    "marks": {
      "skippingStones": "You show up, you help, you get a stamp. The stamps add up. That's a Mark. No financial value, just proof you participated.",
      "wadingIn": "Marks are the platform's record of your contribution. They unlock access, reduce your Cost+20% purchases, and signal your standing. They are not money and not equity."
    }
  }
